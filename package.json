    "report:missing-media": "npm run audit:assets && node tools/build_missing_media_registry.mjs",
    "report:media-canon": "node tools/report_media_canon.mjs",
    "report:media-replacements": "node tools/report_media_replacements.mjs",
    "materialize:placeholder-preview": "node tools/materialize_placeholder_preview.mjs",
    "test:parser": "node tests/parser_contract_check.mjs",
    "test:runner": "node tests/runner_smoke_check.mjs",
    "test:pipelines": "node tests/real_pipeline_madonna_check.mjs",
    "test:kerigma": "node tests/real_pipeline_kerigma_check.mjs",
    "test:madonna-track": "node tests/real_pipeline_madonna_track_check.mjs",
    "test:reel-template": "node tests/reel_template_clip_check.mjs",
    "test:media": "node tests/hydrated_media_check.mjs",
    "test:media-catalog": "node tests/media_catalog_check.mjs",
    "test:media-replacements": "node tests/media_replacement_check.mjs",
    "test:placeholder-preview": "node tests/placeholder_preview_materialization_check.mjs",
    "test:media-validation": "node tests/media_validation_check.mjs",
    "test:capcut-pack": "node tests/capcut_pack_hydration_check.mjs",
