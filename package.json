    "run:arc": "node engine/runner/index.js",
    "orchestrate": "node engine/orchestrator/orchestrator.js",
    "test:orchestrator": "node tests/orchestrator_decision_check.mjs",
    "health:check": "npm run test:runtime-guard && npm run test:parser && npm run test:runner && npm run test:orchestrator && npm run test:media-replacements && npm run test:placeholder-preview",
    "test:runtime-guard": "node tools/runtime_guard_check.mjs"
